{{> header}}

<div class="container d-flex flex-column justify-content-center flex-grow-1 py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6 col-xl-5">
            
            <div class="card border-0 shadow-lg rounded-4">
                <div class="card-body p-5">
                    
                    <div class="text-center mb-4">
                        <div class="bg-purple-light rounded-circle d-inline-flex p-3 mb-3">
                            <i class="bi bi-rocket-takeoff-fill text-purple h2 mb-0"></i>
                        </div>
                        <h3 class="fw-bold">Create Account</h3>
                        <p class="text-muted small">Join the community and start hacking.</p>
                    </div>

                    {{#globalError}}
                    <div class="alert alert-danger text-center small mb-4" role="alert">
                        <i class="bi bi-exclamation-octagon-fill me-2"></i>{{globalError}}
                    </div>
                    {{/globalError}}

                    <form action="/register" method="POST">
                        <input type="hidden" name="_csrf" value="{{token}}"/>

                        <div class="row g-2 mb-3">
                            <div class="col-md">
                                <div class="form-floating">
                                    <input type="text" name="firstName" class="form-control {{#errorFirstName}}is-invalid{{/errorFirstName}}" id="floatingName" placeholder="John" value="{{user.firstName}}" required>
                                    <label for="floatingName">First Name</label>
                                    {{#errorFirstName}}
                                        <div class="invalid-feedback">{{errorFirstName}}</div>
                                    {{/errorFirstName}}
                                </div>
                            </div>
                            <div class="col-md">
                                <div class="form-floating">
                                    <input type="text" name="lastName" class="form-control {{#errorLastName}}is-invalid{{/errorLastName}}" id="floatingLast" placeholder="Doe" value="{{user.lastName}}" required>
                                    <label for="floatingLast">Last Name</label>
                                    {{#errorLastName}}
                                        <div class="invalid-feedback">{{errorLastName}}</div>
                                    {{/errorLastName}}
                                </div>
                            </div>
                        </div>

                        <div class="form-floating mb-3">
                            <input type="email" name="email" class="form-control {{#errorEmail}}is-invalid{{/errorEmail}}" id="floatingEmail" placeholder="name@example.com" value="{{user.email}}" required>
                            <label for="floatingEmail">Email address</label>
                            {{#errorEmail}}
                                <div class="invalid-feedback">{{errorEmail}}</div>
                            {{/errorEmail}}
                        </div>

                        <div class="form-floating mb-3">
                            <input type="password" name="password" class="form-control {{#errorPassword}}is-invalid{{/errorPassword}}" id="floatingPass" placeholder="Password" required>
                            <label for="floatingPass">Password</label>
                            {{#errorPassword}}
                                <div class="invalid-feedback">{{errorPassword}}</div>
                            {{/errorPassword}}
                        </div>
                        
                        <div class="form-check mb-4">
                            <input class="form-check-input {{#errorTerms}}is-invalid{{/errorTerms}}" type="checkbox" name="terms" id="terms" required>
                            <label class="form-check-label small text-muted" for="terms">
                                I agree to the <a href="#" class="text-purple text-decoration-none">Terms & Conditions</a>
                            </label>
                            {{#errorTerms}}
                                <div class="invalid-feedback">{{errorTerms}}</div>
                            {{/errorTerms}}
                        </div>

                        <button type="submit" class="btn btn-purple w-100 py-2 fs-5 rounded-3 mb-3 text-center d-block">Register</button>
                    </form>
                </div>
            </div>

            <div class="text-center mt-4">
                <p class="text-muted">Already have an account? 
                    <a href="/login" class="text-purple fw-bold text-decoration-none">Log In</a>
                </p>
            </div>

        </div>
    </div>
</div>

{{> footer}}