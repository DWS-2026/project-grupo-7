{{> header}}

<main class="container my-5 flex-grow-1">
    <div class="row g-5">
        
        <div class="col-lg-8">
            <p class="fw-bold border-bottom pb-2">{{cartCount}} Courses in Cart</p>

            {{#cartItems}}
            <div class="row py-3 border-bottom align-items-start">
                <div class="col-md-3 col-4">
                    <img src="/course/{{course.id}}/image" class="img-fluid rounded border shadow-sm" alt="{{course.title}}">
                </div>
                <div class="col-md-6 col-5">
                    <h6 class="fw-bold mb-1">{{course.title}}</h6>
                    <p class="small text-muted mb-1">By RayoKross Team</p>
                    <div class="d-flex align-items-center mb-2">
                        <span class="fw-bold text-warning small me-1">{{course.rating}}</span>
                        <i class="bi bi-star-fill text-warning small"></i>
                        <span class="text-muted small ms-1">({{course.reviewCount}} ratings)</span>
                    </div>
                    
                    <div class="d-flex gap-3">
                        <form action="/cart/remove/{{course.id}}" method="POST" class="m-0">
                            <input type="hidden" name="_csrf" value="{{token}}"/>
                            <button type="submit" class="btn btn-link text-purple small text-decoration-none fw-bold p-0">Remove</button>
                        </form>
                    </div>
                </div>
                <div class="col-md-3 col-3 text-end">
                    <div class="text-purple fw-bold fs-5">
                        {{#course.isFree}}Free{{/course.isFree}}
                        {{^course.isFree}}{{course.price}}€{{/course.isFree}}
                        <i class="bi bi-tag-fill small"></i>
                    </div>
                </div>
            </div>
            {{/cartItems}}

            {{^cartItems}}
            <div class="py-5 text-center text-muted">
                <i class="bi bi-cart-x display-1 mb-3"></i>
                <h5>Your cart is empty.</h5>
                <p>Keep shopping to find a course!</p>
                <a href="/courses" class="btn btn-purple mt-3">Explore Courses</a>
            </div>
            {{/cartItems}}
            
        </div>

        {{#hasItems}}
        <div class="col-lg-4">
            <div class="sticky-top" style="top: 80px;"> <article class="card shadow-sm p-2 mb-4"> 
                    <div class="card-body">
                        <div class="text-muted fw-bold small">Total:</div>
                        <div class="display-6 fw-bold mb-0">{{totalPrice}}€</div> 
                        <p class="small text-muted">IVA included</p>
                        
                        <form action="/cart/checkout" method="POST">
                            <input type="hidden" name="_csrf" value="{{token}}"/>
                            <button type="submit" class="btn btn-purple w-100 py-2 fw-bold d-flex justify-content-center align-items-center gap-2 shadow-sm mb-3">
                                <span style="font-size: 0.95rem;">Proceed to Checkout</span>
                                <i class="bi bi-bag-check-fill" style="font-size: 1.1rem;"></i>
                            </button>
                        </form>
                        
                        <p class="text-center small text-muted mb-0">You won't be charged yet</p>
                    </div>
                </article>               

                <div class="input-group mb-3">
                    <form action="/cart/apply-coupon" method="POST" class="d-flex w-100">
                        <input type="hidden" name="_csrf" value="{{token}}"/>
                        <input type="text" name="couponCode" class="form-control border-dark form-control-sm rounded-start" placeholder="Enter Coupon">
                        <button class="btn btn-outline-dark fw-bold btn-sm rounded-end" type="submit">Apply</button>
                    </form>
                </div>
                
            </div>
        </div>
        {{/hasItems}}

    </div>
</main>

{{> footer}}