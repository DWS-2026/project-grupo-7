{{> partials/header}}

<main class="container d-flex flex-column justify-content-center align-items-center flex-grow-1 py-5 text-center">
    <i class="bi bi-radar text-purple" style="font-size: 6rem;"></i>
    
    <h1 class="display-1 fw-bold text-dark mb-0 mt-3">404</h1>
    <h2 class="h3 text-muted mb-4">Target Not Found</h2>
    
    <p class="lead mb-4 text-secondary" style="max-width: 600px;">
        It seems you've gone off the radar. The route or resource you are trying to access does not exist on our servers.
    </p>
    
    <a href="/" class="btn btn-purple btn-lg px-5 rounded-pill shadow-sm">
        <i class="bi bi-house-door me-2"></i>Return to Base
    </a>
</main>

{{> partials/footer}}