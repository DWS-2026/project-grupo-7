{{> header}}

<main class="container d-flex flex-column justify-content-center align-items-center flex-grow-1 py-5 text-center">
    <i class="bi bi-exclamation-triangle-fill text-danger" style="font-size: 6rem;"></i>
    
    <h1 class="display-1 fw-bold text-dark mb-0 mt-3">500</h1>
    <h2 class="h3 text-muted mb-4">Internal Server Error</h2>
    
    <p class="lead mb-4 text-secondary" style="max-width: 600px;">
        Our defensive systems have detected an internal anomaly. The RayoKross engineering team has been notified and is currently mitigating the incident.
    </p>
    
    <div class="d-flex gap-3">
        <button onclick="window.history.back()" class="btn btn-outline-dark btn-lg px-4 rounded-pill">
            <i class="bi bi-arrow-left me-2"></i>Go Back
        </button>
        <a href="/" class="btn btn-purple btn-lg px-4 rounded-pill shadow-sm">
            <i class="bi bi-shield-check me-2"></i>Return to Home
        </a>
    </div>
</main>

{{> footer}}